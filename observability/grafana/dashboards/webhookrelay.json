{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "WebhookRelay",
  "tags": ["webhookrelay"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Capture -> broadcast latency (p50/p95/p99)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(webhookrelay_capture_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(webhookrelay_capture_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(webhookrelay_capture_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Captured requests / sec by method",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(webhookrelay_capture_total[1m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / sec by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limited (429) req/sec",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{status=\"429\"}[5m]))", "legendFormat": "429/s" }
      ]
    },
    {
      "type": "stat",
      "title": "Live backend instances",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(up{job=\"webhookrelay-backend\"})", "legendFormat": "instances" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database connections (HikariCP)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "idle" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "pending" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage (process / system)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "avg(process_cpu_usage)", "legendFormat": "process" },
        { "expr": "avg(system_cpu_usage)", "legendFormat": "system" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 4xx / 5xx errors / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active WebSocket sessions",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(webhookrelay_ws_sessions_active)",
          "legendFormat": "sessions"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis operations / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(lettuce_command_completion_seconds_count[1m])) by (command)",
          "legendFormat": "{{command}}"
        }
      ]
    }
  ]
}
