# Dev proxy target for the WebhookRelay backend.
# Point this at the backend the frontend should talk to during `npm run dev`.
# Examples:
#   - Local Spring Boot backend:  http://localhost:8080
#   - Your Render deployment:     https://webhookrelay-backend.onrender.com
# Leave blank to default to http://localhost:8080.
VITE_DEV_PROXY=http://localhost:8080
